# Wasender Personal Access Token (account-wide, used to manage sessions)
# Get yours at: https://wasenderapi.com/settings/tokens
WASENDER_PAT=

# These are populated automatically by /wa during wa-setup. Don't fill in manually.
WASENDER_SESSION_ID=
WASENDER_API_KEY=
WASENDER_WEBHOOK_SECRET=
WASENDER_PHONE=

# Render API key (used in wa-deploy)
# Get yours at: https://dashboard.render.com/u/settings#api-keys
RENDER_API_KEY=

# Anthropic API key (used by the generated bot for the LLM)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
